# Cloudflare Pages : ne jamais figer le HTML ni les marqueurs de version.
# Les assets JS/CSS/images peuvent rester gérés par Cloudflare, mais les pages
# et config doivent toujours être revalidées pour éviter les mélanges de builds.
/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/**/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/login/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/config.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/version.txt
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0

/version.json
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
